{
  "name": "aster-code-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Aster Code Coding-Agent Studio",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:runtime": "npm run dev --workspace=apps/runtime",
    "runtime:dev": "npm run dev --workspace=apps/runtime",
    "runtime:build": "npm run build --workspace=apps/runtime",
    "dev": "concurrently \"npm run dev:runtime\" \"npm run dev:web\"",
    "start": "npm run start --workspace=apps/runtime",
    "check": "npm run typecheck && npm run build && npm run runtime:build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
